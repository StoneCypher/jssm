// The shared style-items body for the `transition: {}` and `graph: {}`
// default-config blocks.  It accepts the same per-state style items as a
// `state: {}` block (so `color: red;` parses), plus the graph-default
// edge-color line (`edge-color`/`edge_color`).
ConfigStyleItems
  = GraphDefaultEdgeColor
  / items:StateDeclarationItem+ { return items; }

ConfigTransition
  = WS? "transition" WS? ":" WS? "{" WS? items:ConfigStyleItems? WS? "};" WS? {
      const node: any = { key: "default_transition_config", value: items || [] };
      if (options.locations) { node.loc = location(); }
      return node;
    }

// `graph: { ... };` — graph-scope styling defaults, the Graphviz
// *graph*-scope mirror of `state:` (node) and `transition:` (edge).
// Distinct from `start_states`/`end_states`, which are structural config.
ConfigGraph
  = WS? "graph" WS? ":" WS? "{" WS? items:ConfigStyleItems? WS? "};" WS? {
      const node: any = { key: "default_graph_config", value: items || [] };
      if (options.locations) { node.loc = location(); }
      return node;
    }





ConfigGraphLayout
  = WS? "graph_layout"    WS? ":" WS? value:GvizLayout WS? ";" WS? {
      const node: any = { key: "graph_layout", value: value };
      if (options.locations) { node.loc = location(); }
      return node;
    }

ConfigStartNodes
  = WS? "start_states"    WS? ":" WS? value:LabelList  WS? ";" WS? {
      const node: any = { key: "start_states", value: value };
      if (options.locations) { node.loc = location(); }
      return node;
