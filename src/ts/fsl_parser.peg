      const node: any = { key: 'arrow probability', value: value };
      if (options.locations) { node.loc = location(); }
      return node;
    }





TimeType
  = 'milliseconds' { return 1;                       }
  / 'millisecond'  { return 1;                       }
  / 'msecs'        { return 1;                       }
  / 'msec'         { return 1;                       }
  / 'ms'           { return 1;                       }

  / 'seconds'      { return 1000;                    }
  / 'second'       { return 1000;                    }
  / 'secs'         { return 1000;                    }
  / 'sec'          { return 1000;                    }
  / 's'            { return 1000;                    }

  / 'minutes'      { return 1000 * 60;               }
  / 'minute'       { return 1000 * 60;               }
  / 'mins'         { return 1000 * 60;               }
  / 'min'          { return 1000 * 60;               }
  / 'm'            { return 1000 * 60;               }

  / 'hours'        { return 1000 * 60 * 60;          }
  / 'hour'         { return 1000 * 60 * 60;          }
  / 'hrs'          { return 1000 * 60 * 60;          }
  / 'hr'           { return 1000 * 60 * 60;          }
  / 'h'            { return 1000 * 60 * 60;          }

  / 'days'         { return 1000 * 60 * 60 * 24;     }
  / 'day'          { return 1000 * 60 * 60 * 24;     }
  / 'd'            { return 1000 * 60 * 60 * 24;     }

  / 'weeks'        { return 1000 * 60 * 60 * 24 * 7; }
  / 'week'         { return 1000 * 60 * 60 * 24 * 7; }
  / 'wks'          { return 1000 * 60 * 60 * 24 * 7; }
  / 'wk'           { return 1000 * 60 * 60 * 24 * 7; }
  / 'w'            { return 1000 * 60 * 60 * 24 * 7; }


ArrowAfter
  = 'after' WS value:NonNegNumber WS? timescale:TimeType? { return value * (timescale || 1000); }





LabelList
  = "[" WS? names:(Label WS?)* "]" { return names.map(i => i[0]); }

LabelOrLabelList
  = LabelList
  / Label

// A bare reference to a named group, written `&Name`.  Used wherever a
// group may stand in for a state: as a transition source/target, as a
// `state` declaration subject, and as a hook subject.  Distinct from the
// `&Name : [...]` declaration form (NamedList), which defines a group.
GroupRef "group reference"
  = "&" WS? name:Label { return { key: 'group_ref', name }; }

// A single member inside a group-membership list.  Members are ordered.
// A `&child` member nests the child group (structure-preserving); a
// `...&child` member spreads the child's members in flat (identity-
// erasing).  A bare label is an ordinary state member.
GroupMember
  = "..." WS? "&" WS? name:Label { return { kind: 'group', name, mode: 'spread' }; }
  /            "&" WS? name:Label { return { kind: 'group', name, mode: 'nest'   }; }
  /            name:Label         { return { kind: 'state', name             }; }

// The membership list for a NamedList declaration.  Backward-compatible:
// when every member is a plain label the result is a bare `string[]`
// (the historical NamedList value shape, relied on across the suite); as
// soon as any member is a `&`/`...&` group reference the whole list is
// returned as ordered member objects so nest/spread structure survives.
GroupMemberList
  = "[" WS? members:(GroupMember WS?)* "]" {
      const items = members.map(m => m[0]);
      const has_group = items.some(m => m.kind === 'group');
      return has_group ? items : items.map(m => m.name);
    }

Stripe
  = '+|' n:$(NonZeroDigit DecimalDigit*) {
      const node: any = { key: 'stripe', value:      parseInt(n, 10) };
      if (options.locations) { node.loc = location(); }
      return node;
    }
  / '-|' n:$(NonZeroDigit DecimalDigit*) {
      const node: any = { key: 'stripe', value: -1 * parseInt(n, 10) };
      if (options.locations) { node.loc = location(); }
      return node;
    }

Cycle
  = '+' n:$(NonZeroDigit DecimalDigit*) {
      const node: any = { key: 'cycle', value:      parseInt(n, 10) };
      if (options.locations) { node.loc = location(); }
      return node;
    }
  / '-' n:$(NonZeroDigit DecimalDigit*) {
      const node: any = { key: 'cycle', value: -1 * parseInt(n, 10) };
      if (options.locations) { node.loc = location(); }
      return node;
    }
  / '+0'                                 {
      const node: any = { key: 'cycle', value: 0 };
      if (options.locations) { node.loc = location(); }
      return node;
    }

ArrowTarget
  = Stripe
  / Cycle
  / LabelList
  / GroupRef
  / Label





// Decorations on either side of an arrow may appear in any order.
// Each kind may appear at most once per side; duplicates are a parse
// error.  The shared ArrowDecoration rule is used on both sides; the
// asymmetric AST mapping (which side stores under which prefix) lives
// in the Subexp action block below.

ArrowDecoration
  = v:ArrowAfter        { return { _kind: 'after',  v: v }; }
  / v:ActionLabel       { return { _kind: 'action', v: v, loc: location() }; }
  / v:ArrowProbability  { return { _kind: 'prob',   v: v }; }
  / v:ArrowDesc         { return { _kind: 'desc',   v: v }; }

ArrowDecorations
  = (d:ArrowDecoration WS? { return d; })*

Subexp
  = WS? pre   : ArrowDecorations
    WS? arrow : Arrow
    WS? post  : ArrowDecorations
    WS? label : ( l:ArrowTarget { return options.locations ? { __v: l, __loc: location() } : l; } )
    WS? tail  : Subexp? {

      // Reminder: remove this type and the one in Exp if you want to work in pegjs online
      // TODO: properly type this
      const toVal = options.locations ? label.__v : label;
      const base: any = { kind: arrow, to: toVal };

      // AST field-name conventions inherited from the original
      // fixed-order rule:
      //   pre-arrow:  after→r_after  action→r_action  prob→r_probability  desc→l_desc
      //   post-arrow: after→l_after  action→l_action  prob→l_probability  desc→r_desc
      // The `!= null` guard suppresses missing-value sentinels (the
      // `null` returned by an empty `{}` brace block) while letting
      // legitimately-empty primitives through — notably the empty
      // string from an empty action label `''`.
      const seen: any = {};
      for (const d of pre) {
        if (seen['pre:' + d._kind]) { error('duplicate ' + d._kind + ' decoration before arrow', location()); }
        seen['pre:' + d._kind] = true;
        if (d._kind === 'after'  && d.v != null) { base.r_after       = d.v;       }
        if (d._kind === 'action' && d.v != null) { base.r_action = d.v; if (options.locations) { base.r_action_loc = d.loc; } }
        if (d._kind === 'prob'   && d.v != null) { base.r_probability = d.v.value; }
        if (d._kind === 'desc'   && d.v != null) { base.l_desc        = d.v;       }
      }
      for (const d of post) {
        if (seen['post:' + d._kind]) { error('duplicate ' + d._kind + ' decoration after arrow', location()); }
        seen['post:' + d._kind] = true;
        if (d._kind === 'after'  && d.v != null) { base.l_after       = d.v;       }
        if (d._kind === 'action' && d.v != null) { base.l_action = d.v; if (options.locations) { base.l_action_loc = d.loc; } }
        if (d._kind === 'prob'   && d.v != null) { base.l_probability = d.v.value; }
        if (d._kind === 'desc'   && d.v != null) { base.r_desc        = d.v;       }
      }

      if (tail) { base.se = tail; }

      if (options.locations) { base.loc = location(); base.to_loc = label.__loc; }

      return base;

    }





Exp
  = label:( l:ArrowTarget { return options.locations ? { __v: l, __loc: location() } : l; } )
    se:Subexp WS? ';' WS? {
    // Reminder: remove this type and the one in subexp if you want to work in pegjs online
    // TODO: properly type this
    const fromVal = options.locations ? label.__v : label;
    const base: any = { key: 'transition', from: fromVal };
    if (se) { base.se = se; }
    if (options.locations) { base.loc = location(); base.from_loc = label.__loc; }
    return base;
  }






