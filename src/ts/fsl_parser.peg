ConfigAllowIslands
  = WS? "allow_islands" WS? ":" WS?
    value:( v:IslandsT { return options.locations ? { __v: v, __loc: location() } : v; } )
    WS? ";" WS? {
      const raw = options.locations ? value.__v : value;
      const node: any = { key: "allow_islands", value: raw };
      if (options.locations) { node.loc = location(); node.value_loc = value.__loc; }
      return node;
    }





OverrideT
  = 'true'      { return true;      }
  / 'false'     { return false;     }
  / 'undefined' { return undefined; }

IslandsT
  = 'with_start' { return 'with_start'; }
  / 'true'       { return true;         }
  / 'false'      { return false;        }





Config "configuration"
  = ConfigGraphLayout
  / ConfigStartNodes
  / ConfigEndNodes
  / ConfigFailedOutputs
  / ConfigTransition
  / ConfigGraph
  / ConfigAnyState
  / ConfigGraphBgColor
  / ConfigAllowsOverride
  / ConfigAllowIslands





