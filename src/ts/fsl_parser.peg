StateDeclarationItem
  = SdStateLabel
  / SdStateColor
  / SdStateTextColor
  / SdStateBackgroundColor
  / SdStateBorderColor
  / SdStateShape
  / SdStateCorners
  / SdStateLineStyle
  / SdStateImage
  / SdStateUrl
  / SdStateProperty

StateDeclarationDesc
  = "{" WS? items:StateDeclarationItem* WS? "}" { return items; }

StateDeclaration
  = WS? "state" WS
    name:( n:GroupRef { return options.locations ? { __v: n, __loc: location() } : n; } )
    WS? ":" WS? value:StateDeclarationDesc WS? ";" WS? {
      const raw  = options.locations ? name.__v : name;
      const node: any = { key: 'state_declaration', name: raw, value };
      if (options.locations) { node.loc = location(); node.name_loc = name.__loc; }
      return node;
    }
  / WS? "state" WS
    name:( n:Label { return options.locations ? { __v: n, __loc: location() } : n; } )
    WS? ":" WS? value:StateDeclarationDesc WS? ";" WS? {
      const raw  = options.locations ? name.__v : name;
      const node: any = { key: 'state_declaration', name: raw, value };
      if (options.locations) { node.loc = location(); node.name_loc = name.__loc; }
      return node;
    }





NamedList
  = WS? "&" WS? name:Label WS? ":" WS? value:GroupMemberList WS? ";" WS? {
      const node: any = { key:'named_list', name, value };
      if (options.locations) { node.loc = location(); }
      return node;
    }
  / WS? "&" WS? name:Label WS? ":" WS? value:Label WS? ";" WS? {
      const node: any = { key:'named_list', name, value };
      if (options.locations) { node.loc = location(); }
      return node;
    }




// The boundary event a hook listens for: `enter` fires when a transition
// crosses into the subject's boundary, `exit` when it crosses out.
HookEvent "hook event (enter/exit)"
  = "enter"
  / "exit"

// `on <enter|exit> <&group|state> do '<action>';` — registers a boundary
// hook on a group reference or a plain state.  The action is an
// ActionLabel (a quoted action name).
HookDeclaration "hook declaration"
  = WS? "on" WS event:HookEvent WS subject:(GroupRef / Label) WS "do" WS action:ActionLabel WS? ";" WS? {
      const node: any = { key: 'hook_decl', event, subject, action };
      if (options.locations) { node.loc = location(); }
      return node;
    }





MachinePropertyDefault
  = PropertyVal
//   / MachinePropertyDefaultArray
//   / MachinePropertyDefaultObject

MachineProperty
  = WS? "property" WS name:Label WS 'default' WS default_value:MachinePropertyDefault WS  'required' WS? ";" WS? {
      const node: any = { key:'property_definition', name, default_value, required: true };
      if (options.locations) { node.loc = location(); }
      return node;
    }
  / WS? "property" WS name:Label                                                      WS  'required' WS? ";" WS? {
      const node: any = { key:'property_definition', name, required: true };
      if (options.locations) { node.loc = location(); }
      return node;
    }
  / WS? "property" WS name:Label WS 'default' WS default_value:MachinePropertyDefault                WS? ";" WS? {
      const node: any = { key:'property_definition', name, default_value };
      if (options.locations) { node.loc = location(); }
      return node;
    }
  / WS? "property" WS name:Label                                                                     WS? ";" WS? {
      const node: any = { key:'property_definition', name };
      if (options.locations) { node.loc = location(); }
      return node;
    }





MachineVal
  = WS? "val" WS name:Label WS? ":" WS? vtype:ValType WS "default" WS dval:ValVal WS "required" WS? ";" WS? {
      const node: any = { key: 'val_definition', name, val_type: vtype, default_value: dval, required: true };
      if (options.locations) { node.loc = location(); }
      return node;
    }
  / WS? "val" WS name:Label WS? ":" WS? vtype:ValType WS "required" WS? ";" WS? {
      const node: any = { key: 'val_definition', name, val_type: vtype, required: true };
      if (options.locations) { node.loc = location(); }
      return node;
    }
  / WS? "val" WS name:Label WS? ":" WS? vtype:ValType WS "default" WS dval:ValVal WS? ";" WS? {
      const node: any = { key: 'val_definition', name, val_type: vtype, default_value: dval };
      if (options.locations) { node.loc = location(); }
      return node;
    }
  / WS? "val" WS name:Label WS? ":" WS? vtype:ValType WS? ";" WS? {
      const node: any = { key: 'val_definition', name, val_type: vtype };
      if (options.locations) { node.loc = location(); }
      return node;
    }

ValType
  = ValTypeInt
  / ValTypeBoolean
  / ValTypeString
  / ValTypeEnum

ValTypeBoolean = "boolean" { return { kind: 'boolean' }; }
ValTypeString  = "string"  { return { kind: 'string' }; }

ValTypeInt
  = "int" range:ValIntRange? {
      return range === null ? { kind: 'int' } : { kind: 'int', lo: range.lo, hi: range.hi };
    }

ValIntRange
  = WS lo:ValSignedInt WS? ".." WS? hi:ValSignedInt { return { lo, hi }; }

ValSignedInt
  = chars:$("-"? [0-9]+) { return parseInt(chars, 10); }

ValTypeEnum
  = "enum" WS? "(" WS? first:ValEnumMember rest:(WS? "," WS? m:ValEnumMember { return m; })* WS? ")" {
      return { kind: 'enum', members: [first, ...rest] };
    }

// An enum member is an atom-like identifier that, crucially, excludes the comma
// (the real Atom rule includes ",", so it would swallow the list separator).
ValEnumMember
  = chars:$([0-9a-zA-Z\.\_\!\$\^\*\?\x80-￿]+) { return chars; }

ValVal
  = String
  / Boolean
  / neg:"-"? num:JsNumericLiteral { return neg ? -num : num; }
  / Atom



RegularArrangeDeclaration
  = "arrange"       WS? value:LabelOrLabelList WS? ";" WS? {
      const node: any = { key: 'arrange_declaration', value };
      if (options.locations) { node.loc = location(); }
      return node;
    }

ArrangeStartDeclaration
  = "arrange-start" WS? value:LabelOrLabelList WS? ";" WS? {
      const node: any = { key: 'arrange_start_declaration', value };
      if (options.locations) { node.loc = location(); }
      return node;
    }

ArrangeEndDeclaration
  = "arrange-end"   WS? value:LabelOrLabelList WS? ";" WS? {
      const node: any = { key: 'arrange_end_declaration', value };
      if (options.locations) { node.loc = location(); }
      return node;
    }

ArrangeDeclaration "arrange declaration"
  = ArrangeStartDeclaration
  / ArrangeEndDeclaration
  / RegularArrangeDeclaration





Term
