  / "head_label"
  / "tail_label"

ArrowItem
  = WS? key:ArrowItemKey WS? ":" WS? value:Label WS? ";" WS? {
      const node: any = { key:key, value:value };
      if (options.locations) { node.loc = location(); }
      return node;
    }

SingleEdgeColor "single edge color"
  = WS? "edge-color" WS? ":" WS?
    value:( v:Color { return options.locations ? { __v: v, __loc: location() } : v; } )
    WS? ";" WS? {
      const raw = options.locations ? value.__v : value;
      const node: any = { key: 'single_edge_color', value: raw };
      if (options.locations) { node.loc = location(); node.value_loc = value.__loc; }
      return node;
    }
  / WS? "edge_color" WS? ":" WS?
    value:( v:Color { return options.locations ? { __v: v, __loc: location() } : v; } )
    WS? ";" WS? {
      const raw = options.locations ? value.__v : value;
      const node: any = { key: 'single_edge_color', value: raw };
      if (options.locations) { node.loc = location(); node.value_loc = value.__loc; }
      return node;
    }

TransitionLineStyle "transition line style"
  = WS? "line-style" WS? ":" WS? value:LineStyle WS? ";" WS? {
      const node: any = { key:'transition_line_style', value:value };
      if (options.locations) { node.loc = location(); }
      return node;
    }

ArrowItems
  = SingleEdgeColor
  / TransitionLineStyle
  / ArrowItem+

ArrowDesc
  = "{" WS? items:ArrowItems? WS? "}" { return items; }

ArrowProbability
