      if (options.locations) { node.loc = location(); }
      return node;
    }

ConfigFailedOutputs
  = WS? "failed_outputs"  WS? ":" WS?
    value:( v:LabelOrLabelList { return options.locations ? { __v: v, __loc: location() } : v; } )
    WS? ";" WS? {
      const raw = options.locations ? value.__v : value;
      const node: any = { key: "failed_outputs", value: typeof raw === 'string' ? [raw] : raw };
      if (options.locations) { node.loc = location(); node.value_loc = value.__loc; }
      return node;
    }

ConfigGraphBgColor
  = WS? "graph_bg_color"  WS? ":" WS?
    value:( v:Color { return options.locations ? { __v: v, __loc: location() } : v; } )
    WS? ";" WS? {
      const raw = options.locations ? value.__v : value;
