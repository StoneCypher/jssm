{
  "manifest": "teaching-surface",
  "verified": "2026-06-27",
  "spec": "notes/superpowers/specs/2026-06-27-help-bar-teaching-surface.md",
  "note": "Multi-surface. Language features use grammar.rules as their claims; other surfaces use units. Surfaces 2-7 are v5-provisional pending StoneCypher/jssm#822 (v6 re-enumeration).",
  "groundTruths": {
    "language": "src/ts/fsl_parser.peg",
    "api": "src/ts/jssm.ts (exported symbols)",
    "viz": "src/ts/jssm_viz.ts (exported symbols)",
    "editor": "src/ts/cm6/fsl_language.ts (exported symbols)",
    "webcomponent": "custom-elements.json (CEM tag names)",
    "cli": "package.json bin + src/ts/cli (subcommands, render targets, dispatcher flags)",
    "llm-prompt": "src/ts/cli/subcommands/export-system-prompt/plugin.ts (prompt headings)"
  },
  "features": [
    {
      "id": "doc-structure",
      "surface": "language",
      "title": "Document structure",
      "grammar": { "rules": ["Document", "Term", "TermList"], "terminals": [] },
      "tier": "core",
      "dependsOn": [],
      "indexTerms": ["document", "term", "statement", "top level"],
      "referenceAnchor": "1-document-shape"
    },
    {
      "id": "comments",
      "surface": "language",
      "title": "Comments",
      "grammar": { "rules": ["LineComment", "BlockComment"], "terminals": ["//", "/*", "*/"] },
      "tier": "core",
      "dependsOn": ["doc-structure"],
      "indexTerms": ["comment", "//", "/*", "block comment", "line comment"]
    },
    {
      "id": "transitions",
      "surface": "language",
      "title": "Transitions",
      "grammar": {
        "rules": ["Exp", "Subexp", "Arrow", "ArrowTarget", "MixedArrow", "ForwardLightArrow", "BackLightArrow", "TwoWayLightArrow", "LightArrow"],
        "terminals": ["->", "<-", "<->", "→", "←", "↔"]
      },
      "tier": "core",
      "dependsOn": ["labels-quoting"],
      "indexTerms": ["transition", "arrow", "edge", "->", "<-", "<->"],
      "referenceAnchor": "3-transitions"
    },
    {
      "id": "arrow-flavors",
      "surface": "language",
      "title": "Arrow flavors (fat, tilde, light)",
      "grammar": {
        "rules": ["FatArrow", "FatLightArrow", "FatTildeArrow", "ForwardFatArrow", "ForwardTildeArrow", "BackFatArrow", "BackTildeArrow", "LightFatArrow", "LightTildeArrow", "TildeArrow", "TildeFatArrow", "TildeLightArrow", "TwoWayFatArrow", "TwoWayTildeArrow"],
        "terminals": ["=>", "~>", "<=>", "<~>", "⇒", "⇔"]
      },
      "tier": "advanced",
      "dependsOn": ["transitions"],
      "indexTerms": ["fat arrow", "tilde arrow", "=>", "~>", "legal", "main path", "forced"],
      "teachingNote": "Unicode glyphs (→ ⇒ ↔ …) are taught here at advanced tier; you may use them in place of the ASCII forms."
    },
    {
      "id": "timed-transitions",
      "surface": "language",
      "title": "Timed transitions (after)",
      "grammar": { "rules": ["ArrowAfter", "TimeType"], "terminals": ["after", "ms", "s", "sec", "second", "seconds", "min", "minute", "hour", "day", "week"] },
      "tier": "intermediate",
      "dependsOn": ["transitions"],
      "indexTerms": ["after", "timeout", "delay", "timer", "seconds"],
      "footguns": [
        { "id": "after-unit-seconds", "summary": "Bare `after N` defaults to SECONDS, not milliseconds (the implicit scale is 1000).", "indexTerms": ["after", "seconds", "milliseconds", "unit", "1000"] }
      ]
    },
    {
      "id": "weighted-arrows",
      "surface": "language",
      "title": "Weighted / probabilistic arrows",
      "grammar": {
        "rules": ["ArrowProbability", "Cycle", "NonNegNumber", "IntegerLiteral", "JsNumericLiteral", "JsBinaryIntegerLiteral", "JsDecimalIntegerLiteral", "JsDecimalLiteral", "JsHexIntegerLiteral", "JsNExponentIndicator", "JsNExponentPart", "JsNSignedInteger", "NonJsOctalIntegerLiteral"],
        "terminals": ["%", "Pi", "Phi", "Infinity", "NaN", "π", "φ", "∞"]
      },
      "tier": "advanced",
      "dependsOn": ["transitions"],
      "indexTerms": ["probability", "weight", "percent", "random", "cycle", "Pi", "Infinity"],
      "footguns": [
        { "id": "no-negative-zero", "summary": "`Cycle` accepts `+0` but not `-0` or bare `0` (zero is treated as unsigned).", "indexTerms": ["zero", "-0", "+0", "cycle"] }
      ]
    },
    {
      "id": "arrow-decorations",
      "surface": "language",
      "title": "Per-arrow decorations (labels, colors)",
      "grammar": { "rules": ["ArrowDesc", "ArrowDecoration", "ArrowDecorations", "ArrowItem", "ArrowItems", "ArrowItemKey"], "terminals": ["arc_label", "head_label", "tail_label", "edge-color", "line-style"] },
      "tier": "advanced",
      "dependsOn": ["transitions", "colors"],
      "indexTerms": ["arrow label", "edge label", "arc_label", "head_label", "tail_label", "per-arrow color"]
    },
    {
      "id": "labels-quoting",
      "surface": "language",
      "title": "Labels and quoting",
      "grammar": {
        "rules": ["Label", "String", "Atom", "AtomFirstLetter", "AtomLetter", "ActionLabel", "ActionLabelChar", "ActionLabelQuoteMark", "ActionLabelUnescaped", "QuoteMark", "Char", "Escape", "Unescaped", "Stripe"],
        "terminals": ["\"", "'"]
      },
      "tier": "core",
      "dependsOn": ["doc-structure"],
      "indexTerms": ["label", "string", "atom", "quote", "name", "action"],
      "referenceAnchor": "5-labels-strings-atoms",
      "footguns": [
        { "id": "quote-semantics", "summary": "Double quotes parse as string literals; single quotes parse as action labels. Their escape vocabularies differ.", "indexTerms": ["quote", "single", "double", "string", "action label"] }
      ]
    },
    {
      "id": "states",
      "surface": "language",
      "title": "State declarations",
      "grammar": { "rules": ["StateDeclaration", "StateDeclarationDesc", "StateItems"], "terminals": ["state"] },
      "tier": "core",
      "dependsOn": ["labels-quoting"],
      "indexTerms": ["state", "node", "declaration"]
    },
    {
      "id": "state-styling",
      "surface": "language",
      "title": "State styling",
      "grammar": {
        "rules": ["StateDeclarationItem", "SdStateColor", "SdStateTextColor", "SdStateBackgroundColor", "SdStateBorderColor", "SdStateShape", "SdStateCorners", "SdStateLineStyle", "SdStateImage", "SdStateUrl", "SdStateLabel", "SdStateProperty"],
        "terminals": ["color", "text-color", "background-color", "border-color", "shape", "corners", "line-style", "image", "url", "property"]
      },
      "tier": "intermediate",
      "dependsOn": ["states", "colors"],
      "indexTerms": ["style", "color", "shape", "border", "background", "image", "node style"]
    },
    {
      "id": "colors",
      "surface": "language",
      "title": "Colors",
      "grammar": { "rules": ["Color", "SvgColor", "SvgColorLabel", "Rgb3", "Rgb6", "Rgba4", "Rgba8"], "terminals": ["#", "AliceBlue", "Red", "Blue"] },
      "tier": "intermediate",
      "dependsOn": [],
      "indexTerms": ["color", "svg color", "hex", "rgb", "rgba", "#"],
      "teachingNote": "Teach the PascalCase canonical form (AliceBlue). The lowercase form (aliceblue) also parses and may be noted, but PascalCase is canonical. `#rrggbb` hex is also accepted."
    },
    {
      "id": "shapes",
      "surface": "language",
      "title": "State shapes",
      "grammar": { "rules": ["GvizShape"], "terminals": ["box", "circle", "ellipse", "diamond", "doublecircle"] },
      "tier": "advanced",
      "dependsOn": ["state-styling"],
      "indexTerms": ["shape", "box", "circle", "ellipse", "graphviz shape"]
    },
    {
      "id": "line-styles",
      "surface": "language",
      "title": "Line styles",
      "grammar": { "rules": ["LineStyle", "TransitionLineStyle"], "terminals": ["solid", "dashed", "dotted", "bold"] },
      "tier": "intermediate",
      "dependsOn": ["state-styling"],
      "indexTerms": ["line style", "dashed", "dotted", "solid", "bold"]
    },
    {
      "id": "corners",
      "surface": "language",
      "title": "Corner styles",
      "grammar": { "rules": ["Corners"], "terminals": ["rounded", "regular"] },
      "tier": "advanced",
      "dependsOn": ["state-styling"],
      "indexTerms": ["corners", "rounded", "regular"]
    },
    {
      "id": "directions",
