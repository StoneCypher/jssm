{
  "name": "jssm",
  "version": "5.162.32",
  "engines": {
    "node": ">=10.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "fsl": "./dist/cli/fsl.cjs",
    "jssm": "./dist/cli/fsl.cjs",
    "fsl-render": "./dist/cli/fsl-render.cjs",
    "fsl-export-system-prompt": "./dist/cli/fsl-export-system-prompt.cjs"
  },
  "exports": {
    ".": {
      "require": {
        "types": "./jssm.es5.d.cts",
        "default": "./dist/jssm.es5.cjs"
      },
      "import": {
        "types": "./jssm.es6.d.ts",
        "default": "./dist/jssm.es6.mjs"
      },
      "default": {
        "types": "./jssm.es5.d.cts",
        "default": "./dist/jssm.es5.cjs"
      },
      "browser": "./dist/jssm.es5.iife.js"
    },
    "./viz": {
      "require": {
        "types": "./jssm_viz.es5.d.cts",
        "default": "./dist/jssm_viz.cjs"
      },
      "import": {
        "types": "./jssm_viz.es6.d.ts",
        "default": "./dist/jssm_viz.mjs"
      },
      "browser": "./dist/jssm_viz.iife.cjs"
    },
    "./cli": {
      "require": {
        "types": "./jssm.cli.d.cts",
        "default": "./dist/cli/lib.cjs"
      },
      "import": {
        "types": "./jssm.cli.d.ts",
        "default": "./dist/cli/lib.mjs"
      }
    },
    "./wc/viz": {
      "import": "./dist/wc/viz.js",
      "default": "./dist/wc/viz.js"
    },
    "./wc/viz/define": {
      "import": "./dist/wc/viz.define.js",
      "default": "./dist/wc/viz.define.js"
    },
    "./wc/instance": {
      "import": "./dist/wc/instance.js",
      "default": "./dist/wc/instance.js"
    },
    "./wc/instance/define": {
      "import": "./dist/wc/instance.define.js",
      "default": "./dist/wc/instance.define.js"
    },
    "./wc/editor": {
      "import": "./dist/wc/editor.js",
      "default": "./dist/wc/editor.js"
    },
    "./wc/editor/define": {
      "import": "./dist/wc/editor.define.js",
      "default": "./dist/wc/editor.define.js"
    },
    "./wc/widgets": {
      "import": "./dist/wc/widgets.js",
      "default": "./dist/wc/widgets.js"
    },
    "./wc/widgets/define": {
      "import": "./dist/wc/widgets.define.js",
      "default": "./dist/wc/widgets.define.js"
    },
    "./wc/docs": {
      "import": "./dist/wc/docs.js",
      "default": "./dist/wc/docs.js"
    },
    "./wc/docs/define": {
      "import": "./dist/wc/docs.define.js",
      "default": "./dist/wc/docs.define.js"
    },
    "./cm6": {
      "types": "./dist/es6/cm6/fsl_language.d.ts",
      "import": "./dist/cm6/fsl_language.js",
      "default": "./dist/cm6/fsl_language.js"
    },
    "./fence": {
      "types": "./jssm.fence.d.ts",
      "import": "./dist/fence/fence.js",
      "default": "./dist/fence/fence.js"
    },
    "./cdn/viz": "./dist/cdn/viz.js",
    "./cdn/instance": "./dist/cdn/instance.js",
    "./custom-elements.json": "./custom-elements.json"
  },
  "autoupdate": {
    "source": "git",
    "target": "git://github.com/StoneCypher/jssm.git",
    "fileMap": [
      {
        "basePath": "/dist",
        "files": [
          "jssm.es5.cjs"
        ]
      }
    ]
  },
  "type": "module",
  "sideEffects": [
    "./dist/wc/*.define.js",
    "./dist/cdn/**"
  ],
  "files": [
    "dist/jssm.es5.cjs",
    "dist/jssm.es5.iife.js",
    "dist/jssm.es6.mjs",
    "dist/jssm_viz.cjs",
    "dist/jssm_viz.iife.cjs",
    "dist/jssm_viz.mjs",
    "dist/wc/viz.js",
    "dist/wc/viz.define.js",
    "dist/wc/instance.js",
    "dist/wc/instance.define.js",
    "dist/wc/editor.js",
    "dist/wc/editor.define.js",
    "dist/wc/widgets.js",
    "dist/wc/widgets.define.js",
    "dist/wc/docs.js",
    "dist/wc/docs.define.js",
    "dist/cm6/fsl_language.js",
    "dist/es6/cm6/fsl_language.d.ts",
    "dist/fence/fence.js",
    "dist/cdn/viz.js",
    "dist/cdn/instance.js",
    "dist/cli/lib.cjs",
    "dist/cli/lib.mjs",
    "dist/deno/jssm.js",
    "dist/deno/*.d.ts",
    "dist/deno/README.md",
    "jssm.es5.d.cts",
    "jssm.es6.d.ts",
    "jssm_viz.es5.d.cts",
    "jssm_viz.es6.d.ts",
    "jssm.cli.d.cts",
    "jssm.cli.d.ts",
    "jssm.fence.d.ts",
    "MIGRATING-jssm-viz.md",
    "custom-elements.json"
  ],
  "description": "A Javascript finite state machine (FSM) with a terse DSL and a simple API.  Most FSMs are one-liners.  Fast, easy, powerful, well tested, typed with TypeScript, and visualizations. MIT License.",
  "main": "dist/jssm.es5.cjs",
  "module": "dist/jssm.es6.mjs",
  "browser": "dist/jssm.es5.iife.js",
  "types": "./jssm.es5.d.cts",
  "scripts": {
    "vitest-unicode-action": "vitest run --config vitest.unicode.config.ts unicode-actions.uspec.ts",
    "vitest-unicode-string": "vitest run --config vitest.unicode.config.ts unicode-strings.uspec.ts",
    "vitest-unicode-atom": "vitest run --config vitest.unicode.config.ts unicode-atoms.uspec.ts",
    "vitest-unicode-string-label": "vitest run --config vitest.unicode.config.ts unicode-string-labels.uspec.ts",
    "vitest-unicode-atom-label": "vitest run --config vitest.unicode.config.ts unicode-atom-labels.uspec.ts",
    "vitest-unicode-edge-label": "vitest run --config vitest.unicode.config.ts unicode-edge-labels.uspec.ts",
    "vitest-unicode-machine-property": "vitest run --config vitest.unicode.config.ts unicode-machine-properties.uspec.ts",
    "vitest-unicode-error-message": "vitest run --config vitest.unicode.config.ts unicode-error-messages.uspec.ts",
    "vitest-unicode-group-name": "vitest run --config vitest.unicode.config.ts unicode-group-names.uspec.ts",
    "vitest-unicode-state-decl-name": "vitest run --config vitest.unicode.config.ts unicode-state-decl-names.uspec.ts",
    "vitest-unicode-hook": "vitest run --config vitest.unicode.config.ts unicode-hooks.uspec.ts",
    "vitest-unicode-machine-metadata": "vitest run --config vitest.unicode.config.ts unicode-machine-metadata.uspec.ts",
    "vitest-unicode-state-property": "vitest run --config vitest.unicode.config.ts unicode-state-properties.uspec.ts",
    "vitest-unicode-image-url": "vitest run --config vitest.unicode.config.ts unicode-state-image-url.uspec.ts",
    "vitest-unicode-arrange": "vitest run --config vitest.unicode.config.ts unicode-arrange.uspec.ts",
    "vitest-unicode-config-state-list": "vitest run --config vitest.unicode.config.ts unicode-config-state-lists.uspec.ts",
    "vitest-unicode-config-state-block": "vitest run --config vitest.unicode.config.ts unicode-config-state-blocks.uspec.ts",
    "vitest-unicode-viz-dot": "vitest run --config vitest.unicode.config.ts unicode-viz-dot.uspec.ts",
    "vitest-unicode-full-slow": "npm run vitest-unicode-atom && npm run vitest-unicode-string && npm run vitest-unicode-atom-label && npm run vitest-unicode-string-label && npm run vitest-unicode-action && npm run vitest-unicode-edge-label && npm run vitest-unicode-machine-property && npm run vitest-unicode-error-message && npm run vitest-unicode-group-name && npm run vitest-unicode-state-decl-name && npm run vitest-unicode-hook && npm run vitest-unicode-machine-metadata && npm run vitest-unicode-state-property && npm run vitest-unicode-image-url && npm run vitest-unicode-arrange && npm run vitest-unicode-config-state-list && npm run vitest-unicode-config-state-block && npm run vitest-unicode-viz-dot",
    "vitest-stoch": "vitest run --config vitest.stoch.config.ts",
    "vitest-dragon": "vitest run --config vitest.dragon.config.ts",
    "vitest-spec": "vitest run --config vitest.spec.config.ts",
    "vitest-docs": "vitest run --config vitest.docs.config.ts",
    "vitest": "npm run vitest-stoch && npm run vitest-spec && npm run vitest-docs",
    "test": "npm run make && npm run vitest",
    "make_cli": "rollup -c rollup.config.cli.js",
    "typecheck_cli": "node --stack-size=4000 node_modules/typescript/bin/tsc --noEmit -p tsconfig.cli.json",
    "typecheck_tests": "node --stack-size=4000 node_modules/typescript/bin/tsc --noEmit -p tsconfig.test.json",
    "min_cli": "terser dist/cli/fsl.cjs -o dist/cli/fsl.cjs --comments=/^#!/ && terser dist/cli/fsl-render.cjs -o dist/cli/fsl-render.cjs --comments=/^#!/ && terser dist/cli/fsl-export-system-prompt.cjs -o dist/cli/fsl-export-system-prompt.cjs --comments=/^#!/ && terser dist/cli/lib.cjs -o dist/cli/lib.cjs && terser dist/cli/lib.mjs -o dist/cli/lib.mjs",
    "clean": "rm -rf dist && rm -rf docs && rm -f tsconfig.tsbuildinfo && cd coverage && rm -rf cloc && cd .. && rm -f src/ts/fsl_parser.ts && rm -f src/ts/version.ts && rm -f src/ts/tests/generated/*.docex.ts && rm -f *.d.ts && mkdir dist && cd dist && mkdir wc && mkdir cdn && cd .. && mkdir docs && cd coverage && mkdir cloc && cd .. && rm -f ./src/tools/jssm.es5.iife.nonmin.js",
    "peg": "rm -f src/ts/fsl_parser.js && pegjs src/ts/fsl_parser.peg && node src/buildjs/fixparser.cjs",
    "build:cem": "custom-elements-manifest analyze --config custom-elements-manifest.config.mjs",
    "make_core": "rollup -c rollup.config.core.js",
    "make_deno": "rollup -c rollup.config.deno.js && cp dist/es6/*.d.ts dist/deno && cp README.md dist/deno",
    "make_viz": "rollup -c rollup.config.viz.js",
    "make_wc_viz_es6": "rollup -c rollup.config.wc.viz.es6.js",
    "make_wc_viz_cdn": "rollup -c rollup.config.wc.viz.cdn.js",
    "make_wc_instance_es6": "rollup -c rollup.config.wc.instance.es6.js",
    "make_wc_instance_cdn": "rollup -c rollup.config.wc.instance.cdn.js",
    "make_wc_editor_es6": "rollup -c rollup.config.wc.editor.es6.js",
    "make_wc_widgets_es6": "rollup -c rollup.config.wc.widgets.es6.js",
    "make_wc_docs_es6": "rollup -c rollup.config.wc.docs.es6.js",
    "make_cm6": "rollup -c rollup.config.cm6.es6.js",
    "make_fence": "rollup -c rollup.config.fence.es6.js",
    "typescript": "node --stack-size=4000 node_modules/typescript/bin/tsc --build tsconfig.json",
    "makever": "node src/buildjs/makever.cjs",
    "make_doctests": "node src/buildjs/extract_examples.cjs",
    "make_help_content": "node src/buildjs/build_help_content.cjs",
    "prep": "npm run makever && npm run peg && npm run make_help_content",
    "make": "node src/buildjs/run_build.cjs --profile=fast",
    "make_ci": "node src/buildjs/run_build.cjs --profile=ci-lite",
    "eslint": "eslint --color src/ts src/buildjs",
    "audit": "text_audit -r -t major MAJOR wasteful WASTEFUL any mixed fixme FIXME checkme CHECKME testme TESTME stochable STOCHABLE todo TODO comeback COMEBACK whargarbl WHARGARBL -g ./src/ts/**/*.{js,ts}",
    "check_teaching_surface": "node src/scripts/teaching_surface/check_teaching_surface.cjs --report",
    "vet": "npm run eslint && npm run audit",
    "benny": "node ./src/buildjs/benchmark.cjs",
    "benny:scaling": "node --expose-gc ./src/buildjs/benchmark_scaling.cjs",
    "benny:all": "npm run benny && npm run benny:scaling",
    "graviton_perf": "node ./src/scripts/graviton_perf_launch.cjs",
    "perf_chart": "node ./src/scripts/make_perf_chart.cjs",
    "ci_profile": "node ./src/buildjs/ci_profile.cjs",
    "build": "node src/buildjs/run_build.cjs --profile=release",
    "clean_bench": "npm run test && npm run benny",
    "qbuild": "npm run test",
    "hosted_test": "node src/buildjs/hosted_test.cjs",
    "e2e:install": "node src/buildjs/playwright_install.cjs",
    "e2e": "npm run e2e:install && node src/buildjs/hosted_test.cjs --serve-dir=.",
    "ci_build": "npm run vet && npm run test",
    "ci_test": "npm run vet && npm run make_ci && npm run vitest",
    "ci_test_runtime": "npm run make_ci && npm run vitest",
    "attw": "attw --pack .",
    "decl_parity": "node src/buildjs/decl_parity.cjs",
    "minify": "mv dist/es6/fsl_parser.js dist/es6/fsl_parser.nonmin.js && terser dist/es6/fsl_parser.nonmin.js > dist/es6/fsl_parser.js",
    "min_iife": "mv dist/jssm.es5.iife.js dist/jssm.es5.iife.nonmin.js && terser dist/jssm.es5.iife.nonmin.js > dist/jssm.es5.iife.js && cp dist/jssm.es5.iife.nonmin.js ./src/tools/",
    "min_cjs": "mv dist/jssm.es5.cjs.js dist/jssm.es5.nonmin.cjs && terser dist/jssm.es5.nonmin.cjs > dist/jssm.es5.cjs",
    "min_es6": "mv dist/jssm.es6.js dist/jssm.es6.nonmin.cjs && terser dist/jssm.es6.nonmin.cjs > dist/jssm.es6.mjs",
    "min_deno": "terser dist/deno/jssm.deno-esm.nonmin.js > dist/deno/jssm.js",
    "min_viz_iife": "mv dist/jssm_viz.es5.iife.js dist/jssm_viz.es5.iife.nonmin.cjs && terser dist/jssm_viz.es5.iife.nonmin.cjs > dist/jssm_viz.iife.cjs",
    "min_viz_cjs": "mv dist/jssm_viz.es5.cjs.js dist/jssm_viz.es5.nonmin.cjs && terser dist/jssm_viz.es5.nonmin.cjs > dist/jssm_viz.cjs",
    "min_viz_es6": "mv dist/jssm_viz.es6.js dist/jssm_viz.es6.nonmin.cjs && terser dist/jssm_viz.es6.nonmin.cjs > dist/jssm_viz.mjs",
    "min_cdn": "terser dist/cdn/viz.js -o dist/cdn/viz.js --module && terser dist/cdn/instance.js -o dist/cdn/instance.js --module",
    "rm_nonmin": "rm ./dist/es6/*.nonmin.js",
    "site": "cp src/site/* docs/ && cp -r src/assets docs/assets/ && cp -r src/demo docs/ && cp dist/jssm.es5.iife.js docs/demo",
    "make_cookbook": "node src/fsl.tools/site/scripts/build.cjs",
    "site_fsl_tools": "cd docs && mkdir fsl.tools && cd .. && cp -r src/fsl.tools/site/* docs/fsl.tools/ && rm -rf docs/fsl.tools/recipes docs/fsl.tools/scripts",
    "build:shootout": "node src/buildjs/build_shootout.mjs",
    "docs": "typedoc src/ts/jssm.ts src/ts/jssm_viz.ts src/ts/jssm_types.ts src/ts/jssm_constants.ts src/ts/jssm_error.ts src/ts/jssm_util.ts src/ts/version.ts --options typedoc-options.cjs",
    "cloc": "cloc --quiet ./src/** --exclude-list-file=./.clocignore --3 --json --out=./coverage/cloc/report_wt.json && cloc --quiet ./src/** --exclude-list-file=./.clocignore --exclude-dir=tests --3 --json --out=./coverage/cloc/report_nt.json && node ./src/buildjs/cloc_report.cjs",
    "readme": "rm -f ./README.md && node ./src/buildjs/make_readme.cjs && cp README.md dist/deno",
    "changelog": "rm -f CHANGELOG.md && rm -f ./src/doc_md/CHANGELOG.md && better_git_changelog -b && cp CHANGELOG.* ./src/doc_md/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StoneCypher/jssm.git"
  },
