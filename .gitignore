# Logs
logs
*.log
npm-debug.log*

# Windows path-mangling artifact: a redirect intended for %TEMP% lands in the
# repo root with backslashes stripped and the drive colon MSYS-encoded as a
# private-use codepoint (U+F03A), so the name renders as CUsers… but isn't
C*Users*vitest_output.txt

# Runtime data
pids
*.pid
*.seed

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules
jspm_packages
.idea

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history

.DS_Store
.rpt2_cache

src/ts/jssm-dot.ts

build/

docs/docs/*.css.map
*.nonmin.js

# TypeScript `tsc --build` incremental cache. The explicit rootDir (added for
# 6.0.3) moves this to the repo root instead of under dist/; it is regenerated
# every build and must never be committed or published.
tsconfig.tsbuildinfo

.claude
.superpowers
.claire
.worktrees
tmp

tmp

# npm config (script-shell path is machine-specific; keep local)
.npmrc

# generated fsl.tools cookbook output (regenerated by `npm run make_cookbook`)
src/fsl.tools/site/cookbook/

# local snapshot of the StoneCypher/fsl issue tracker (regenerable via `gh api`)
fsl-issues.json

# derived analysis artifacts from the issue tracker (regenerable via Node scripts)
lang-issues-open.json
all-open-issues.txt
easy-issues-labelled.json
easy-issues-labelled.txt
notes/easy-issues.md

# generated docblock-example tests (regenerated by `npm run make_doctests`)
src/ts/tests/generated/*.docex.ts

# local benny output — canonical benchmark data comes only from the graviton
# runners (their own results branch); local-host numbers pollute the dataset
benchmark/results/

# generated documentation site (regenerated by `npm run build`; published to
# the gh-pages branch by the deploy-docs CI job — no longer tracked on main)
/docs/

# downloaded local ONNX AI models (run `npm run init:oracle` to fetch)
assets/models/
# Playwright e2e output (regenerated each run)
/test-results/
/playwright-report/
/.playwright-browsers/

# Playwright MCP scratch (page snapshots / console logs from agent browser runs;
# its working dir is pinned to this checkout, so its output lands here)
.playwright-mcp/

# stray browser-debug screenshots that landed in the repo root
phantom-check.png
cc-state.png

# terser intermediates: regenerated by every build, ~18 MB re-churned into
# history per release when tracked.  dist/jssm.es5.nonmin.cjs is DELIBERATELY
# still committed — the graviton perf harness requires it from the checkout
# at every measured commit (src/scripts/graviton_perf.cjs).
/dist/jssm.es6.nonmin.cjs
/dist/jssm_viz.es5.iife.nonmin.cjs
/dist/jssm_viz.es5.nonmin.cjs
/dist/jssm_viz.es6.nonmin.cjs
